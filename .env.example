# MongoDB Atlas connection string
# For Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/stocks
# For local: mongodb://localhost:27017/stocks
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/stocks

# Finnhub API key (get free at https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Server port
PORT=3000

# Comma-separated stock symbols to track
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,TSLA
